# GBT Agent Framework — 环境变量配置
# 复制此文件为 .env 并填入你的API密钥

# ===== 1. 智谱 GLM (国产主力) =====
# 获取: https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=your_zhipu_api_key_here
# 备选变量名: ZHIPUAI_API_KEY, Z_AI_API_KEY, HERMES_API_KEY

# ===== 2. OpenAI GPT =====
# 获取: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# ===== 3. Anthropic Claude =====
# 获取: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===== 4. Google Gemini =====
# 获取: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# ===== 5. DeepSeek =====
# 获取: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===== 6. 阿里 Qwen =====
# 获取: https://dashscope.console.aliyun.com/apiKey
# QWEN_API_KEY=your_qwen_api_key_here

# ===== 7. Mistral =====
# 获取: https://console.mistral.ai/api-keys
# MISTRAL_API_KEY=your_mistral_api_key_here

# ===== 8. xAI Grok =====
# 获取: https://x.ai/api
# GROK_API_KEY=your_grok_api_key_here

# ===== 9. Kimi (Moonshot) =====
# 获取: https://platform.moonshot.cn/console/api-keys
# MOONSHOT_API_KEY=your_kimi_api_key_here

# ===== 10. Step-2 (阶跃星辰) =====
# 获取: https://platform.stepfun.com
# STEPFUN_API_KEY=your_stepfun_api_key_here

# ===== 11. 豆包 (火山引擎) =====
# 获取: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# DOUBAO_API_KEY=your_doubao_api_key_here

# ===== 12. MiniMax =====
# 获取: https://platform.minimax.chat
# MINIMAX_API_KEY=your_minimax_api_key_here

# ===== 网络诊断 =====
# ping 目标地址（默认 8.8.8.8）
PING_TARGET=8.8.8.8

# ===== 13. Ollama (本地) =====
# 安装: https://ollama.com/download
# 无需密钥，安装后运行: ollama serve
